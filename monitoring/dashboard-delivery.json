{
  "title": "Delivery & Service Health",
  "uid": "delivery-health",
  "tags": [
    "delivery",
    "sre"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(app_build_info, service)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "type": "table",
      "title": "What is deployed right now",
      "description": "Build identity per service, straight from the artifact. Ties every metric below to the exact commit that produced it.",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "app_build_info{service=~\"$service\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true,
              "job": true,
              "instance": true,
              "app": true,
              "exported_version": true,
              "pod_version": true
            },
            "renameByName": {
              "service": "Service",
              "build_number": "Build",
              "commit": "Commit",
              "branch": "Branch",
              "version": "Version",
              "environment": "Env",
              "cluster": "Cluster",
              "namespace": "Namespace",
              "pod": "Pod"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Instances up",
      "description": "Scrape targets reporting healthy. A drop here is the first sign a rollout has gone wrong.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(up{service=~\"$service\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Request rate",
      "description": "Requests per second across selected services.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=~\"$service\"}[2m])) + sum(rate(flask_http_request_total{service=~\"$service\"}[2m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Error ratio (5xx)",
      "description": "Proportion of server errors. The HighErrorRate alert fires above 5% sustained for 3m.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{service=~\"$service\",status=~\"5..\"}[5m])) + sum(rate(flask_http_request_total{service=~\"$service\",status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_requests_total{service=~\"$service\"}[5m])) + sum(rate(flask_http_request_total{service=~\"$service\"}[5m])) or vector(1), 0.001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Rollouts observed",
      "description": "Build transitions observed in this window \u2014 deploy frequency, measured from the artifacts actually serving traffic.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(count by (service, build_number) (max_over_time(app_build_info{service=~\"$service\"}[$__range]))) - count(count by (service) (max_over_time(app_build_info{service=~\"$service\"}[$__range])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "timeseries",
      "title": "Request latency p50 / p95 / p99",
      "description": "Tail latency is what users feel. A step change here immediately after a deploy is the classic regression signature.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[2m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[2m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[2m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request rate by service",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\"}[2m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        },
        {
          "expr": "sum by (service) (rate(flask_http_request_total{service=~\"$service\"}[2m]))",
          "legendFormat": "{{service}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory working set",
      "description": "Against the 192Mi container limit declared in the manifests.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_resident_memory_bytes{service=~\"$service\"}",
          "legendFormat": "{{service}} / {{pod}}",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{service=~\"$service\"}",
          "legendFormat": "{{service}} heap",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "CPU utilisation",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{service=~\"$service\"}[2m])",
          "legendFormat": "{{service}} / {{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6
          }
        }
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": "Prometheus",
        "enable": true,
        "iconColor": "orange",
        "expr": "count by (service, build_number) (app_build_info)",
        "titleFormat": "Deploy: {{service}}",
        "textFormat": "build {{build_number}} \u00b7 {{commit}}"
      }
    ]
  }
}
